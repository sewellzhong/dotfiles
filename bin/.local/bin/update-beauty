#!/usr/bin/env bash
set -euo pipefail

magenta='\e[1;35m'
green='\e[1;32m'
red='\e[0;31m'
white='\e[0;37m'
source_dir="$HOME/.local/src"
dry_run=false
assume_yes=false
update_all=false
allow_git_clean=false
install_system=false
selected_commands=()
update_commands=("update_oh-my-zsh" "update_i3" "update_i3blocks"
                 "update_i3lock" "update_rofi" "update_dunst" "update_picom")

# Since some programs are installed in non-root directories,
# don't run this script as root to avoid permission conflict.
if [[ $EUID -eq 0 ]]; then
    echo "Don't run this script as root"
    exit 1
fi

# Print usage message.
usage() {
    local program_name
    program_name=${0##*/}
    cat <<EOF
Usage: $program_name [-option]

Options:
    --help    Print this message
    -n, --dry-run
              Print commands without running them
    -y, --yes Skip confirmation prompts
    --clean   Allow git clean -fd in source repositories
    --install Install built artifacts into system paths
    -a        Update all packages, with per-package confirmation

Components:
    oh-my-zsh, i3, i3blocks, i3lock, rofi, dunst, picom
EOF
}

component_to_command() {
    case "$1" in
        oh-my-zsh|omz)
            printf '%s\n' "update_oh-my-zsh"
            ;;
        i3|i3blocks|i3lock|rofi|dunst|picom)
            printf 'update_%s\n' "$1"
            ;;
        *)
            echo "Unknown component: $1" >&2
            return 1
            ;;
    esac
}

# Tools.
parse_args() {
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -n|--dry-run)
                dry_run=true
                ;;
            -y|--yes)
                assume_yes=true
                ;;
            --clean)
                allow_git_clean=true
                ;;
            --install)
                install_system=true
                ;;
            -a)
                update_all=true
                ;;
            *)
                selected_commands+=("$(component_to_command "$1")")
                ;;
        esac
        shift
    done
}

run() {
    if "$dry_run"; then
        printf '+'
        printf ' %q' "$@"
        printf '\n'
    else
        "$@"
    fi
}

confirm() {
    local message="$1"
    local response

    "$assume_yes" && return 0
    read -r -p "$message [y/N] " response
    case "$response" in
        [yY]|[yY][eE][sS])
            return 0
            ;;
        *)
            echo "Cancelled."
            return 1
            ;;
    esac
}

confirm_install() {
    local component="$1"

    if ! "$install_system"; then
        echo -e "${red}[!] Build complete for $component. Pass --install to write into system paths.${white}"
        return 1
    fi

    "$dry_run" && return 0
    confirm "Install or overwrite $component in system paths with sudo?"
}

confirm_git_clean() {
    echo -e "$magenta\n Files that would be removed by git clean: \n$white"
    run git clean -fdn

    if ! "$allow_git_clean"; then
        echo -e "${red}[!] Skipping git clean. Pass --clean to allow removing untracked files.${white}"
        return 0
    fi

    "$dry_run" && return 0
    confirm "Remove these untracked files?" || return 1
    run git clean -fd
}

row() {
    local cols
    cols="$(tput cols 2>/dev/null || printf '80')"
    seq -s '─' 0 "$cols" | tr -d '[:digit:]'
}

# Get latest release.
get_latest_release() {
    local regex_to_remove_url='sed -re ''s#(http://|https://|git@|git://)github.com(/|:)##'' -e ''s#(/|.git)$##'''
    local username_and_repo
    username_and_repo=$(git config --get remote.origin.url | $regex_to_remove_url)
    check_latest_release() {
        curl -s "https://api.github.com/repos/$username_and_repo/releases/latest" | awk -F '"' '/tag_name/{print $4}'
    }
    if [ -n "$(check_latest_release)" ]; then
        check_latest_release
    else
        curl -s "https://api.github.com/repos/$username_and_repo/tags" | jq -r '.[] | select(.name|test("^(|v)[0-9]")) | .name' | head -n 1
    fi
}

# Use latest release.
use_latest_release() {
    local get_version
    get_version=$(get_latest_release)
    if [ -n "$get_version" ]; then
        confirm_git_clean || return 1
        run git fetch origin tag "$get_version" --no-tags || return 1
        run git checkout "$get_version"
    else
        echo -e "${red}[!] Error: There is an internet connection issue.${white}"
        return 1
    fi
}

# Installer.
update_oh-my-zsh() {
    echo -e "$magenta\n Updating oh-my-zsh... \n$white"
    run zsh "$HOME/.oh-my-zsh/tools/upgrade.sh"
    echo -e "$magenta\n Updating zsh plugins... \n$white"
    cd "$HOME/.oh-my-zsh/custom/plugins" || return
    while IFS= read -r plugin_dir; do
        echo "$plugin_dir"
        run git -C "$plugin_dir" pull
    done < <(find . -mindepth 1 -maxdepth 1 -type d -print)
}

update_i3() {
    echo -e "$magenta\n Updating & compiling i3... \n$white"
    cd "$source_dir/i3" || return
    run rm -rf build
    use_latest_release || return 1
    run mkdir build
    run meson --buildtype=release . build
    run ninja -C build
    echo -e "$green\n Previous i3 version: \n$white"
    row
    i3 -v
    row
    echo -e "$magenta\n Installing i3... \n$white"
    confirm_install "i3" || return 0
    run sudo install -Dm755 --verbose build/i3 /usr/bin/i3
    run sudo install -Dm755 --verbose build/i3bar /usr/bin/i3bar
    run sudo install -Dm755 --verbose build/i3-config-wizard /usr/bin/i3-config-wizard
    run sudo install -Dm755 --verbose build/i3-dump-log /usr/bin/i3-dump-log
    run sudo install -Dm755 --verbose build/i3-input /usr/bin/i3-input
    run sudo install -Dm755 --verbose build/i3-msg /usr/bin/i3-msg
    run sudo install -Dm755 --verbose build/i3-nagbar /usr/bin/i3-nagbar
    run sudo install -Dm755 --verbose i3-dmenu-desktop /usr/bin/i3-dmenu-desktop
    run sudo install -Dm755 --verbose i3-migrate-config-to-v4 /usr/bin/i3-migrate-config-to-v4
    run sudo install -Dm755 --verbose i3-save-tree /usr/bin/i3-save-tree
    run sudo install -Dm755 --verbose i3-sensible-editor /usr/bin/i3-sensible-editor
    run sudo install -Dm755 --verbose i3-sensible-pager /usr/bin/i3-sensible-pager
    run sudo install -Dm755 --verbose i3-sensible-terminal /usr/bin/i3-sensible-terminal
    echo -e "$green\n Current i3 version: \n$white"
    row
    i3 -v
    row
}

update_i3blocks() {
    echo -e "$magenta\n Updating & compiling i3blocks... \n$white"
    cd "$source_dir/i3blocks" || return
    use_latest_release || return 1
    run autoreconf -fi
    run ./configure
    run make
    echo -e "$green\n Previous i3blocks version: \n$white"
    row
    i3blocks -V
    row
    echo -e "$magenta\n Installing i3blocks... \n$white"
    confirm_install "i3blocks" || return 0
    run sudo make install
    echo -e "$green\n Current i3blocks version: \n$white"
    row
    i3blocks -V
    row
    echo -e "$magenta\n Updating i3blocks-contrib... \n$white"
    cd "$source_dir/i3blocks-contrib" || return
    run git pull
}

update_i3lock() {
    echo -e "$magenta\n Updating & compiling i3lock... \n$white"
    cd "$source_dir/i3lock-color" || return
    run rm -rf build
    use_latest_release || return 1
    run autoreconf -i
    run mkdir build
    cd build || return
    run ../configure --enable-debug=no --disable-sanitizers
    run make
    echo -e "$green\n Previous i3lock version: \n$white"
    row
    i3lock -v
    row
    echo -e "$magenta\n Installing i3lock... \n$white"
    confirm_install "i3lock" || return 0
    run sudo make install
    echo -e "$green\n Current i3lock version: \n$white"
    row
    i3lock -v
    row
    echo -e "$magenta\n Updating i3lock-fancy... \n$white"
    cd "$source_dir/i3lock-fancy" || return
    run git pull
    confirm_install "i3lock-fancy" || return 0
    run sudo make install
}

update_rofi() {
    echo -e "$magenta\n Updating & compiling rofi... \n$white"
    cd "$source_dir/rofi" || return
    run rm -rf build
    use_latest_release || return 1
    run git submodule update --init
    run mkdir build
    run meson --buildtype=release . build
    run ninja -C build
    echo -e "$green\n Previous rofi version: \n$white"
    row
    rofi -v
    row
    echo -e "$magenta\n Installing rofi... \n$white"
    confirm_install "rofi" || return 0
    run sudo install -Dm755 --verbose build/rofi /usr/local/bin/rofi
    echo -e "$green\n Current rofi version: \n$white"
    row
    rofi -v
    row
}

update_dunst() {
    echo -e "$magenta\n Updating & compiling dunst... \n$white"
    cd "$source_dir/dunst" || return
    run make clean
    use_latest_release || return 1
    run make WAYLAND=0
    run make dunstify
    echo -e "$green\n Previous dunst version: \n$white"
    row
    dunst -v
    row
    echo -e "$magenta\n Installing dunst... \n$white"
    confirm_install "dunst" || return 0
    run sudo make install
    echo -e "$green\n Current dunst version: \n$white"
    row
    dunst -v
    row
}

update_picom() {
    echo -e "$magenta\n Updating & compiling picom... \n$white"
    cd "$source_dir/picom" || return
    run rm -rf build
    use_latest_release || return 1
    run git submodule update --init
    run meson --buildtype=release . build -Dwith_docs=false
    run ninja -C build
    echo -e "$green\n Previous picom version: \n$white"
    row
    picom --version
    row
    echo -e "$magenta\n Installing picom... \n$white"
    confirm_install "picom" || return 0
    run sudo install -Dm755 --verbose build/src/picom /usr/local/bin/picom
    echo -e "$green\n Current picom version: \n$white"
    row
    picom --version
    row
}

update_one_by_one() {
    local update_command
    local response

    for update_command in "${update_commands[@]}"; do
        echo
        read -r -p "Do you want to ${update_command//_/ }? [y/n] " response
        case $response in
            [yY][eE][sS]|[yY])
                if ! $update_command; then
                    echo -e "${red}[!] ${update_command} failed or was skipped.${white}"
                fi
                ;;
            *)
                echo "Cancelled."
                ;;
        esac
    done
}

update_all_packages() {
    local update_command

    for update_command in "${update_commands[@]}"; do
        if "$assume_yes" || confirm "Run ${update_command//_/ }?"; then
            if ! $update_command; then
                echo -e "${red}[!] ${update_command} failed or was skipped.${white}"
            fi
        fi
    done
}

update_selected_packages() {
    local update_command

    for update_command in "${selected_commands[@]}"; do
        if ! $update_command; then
            echo -e "${red}[!] ${update_command} failed or was skipped.${white}"
        fi
    done
}

main() {
    parse_args "$@"

    if "$dry_run"; then
        echo -e "$red\n Executing in dry-run mode. \n$white"
    fi

    if [ "${#selected_commands[@]}" -gt 0 ]; then
        update_selected_packages
    elif "$update_all"; then
        update_all_packages
    else
        update_one_by_one
    fi
}

main "$@"
