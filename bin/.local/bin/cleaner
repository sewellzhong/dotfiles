#!/usr/bin/env bash

magenta='\e[1;35m'
red='\e[1;31m'
white='\e[0;37m'
dry_run=false
assume_yes=false

shopt -s extglob

# Since some programs are installed in non-root directories,
# don't run this script as root to avoid permission conflict.
if [[ $EUID -eq 0 ]]; then
    echo "Don't run this script as root"
    exit 1
fi

# Print usage message.
usage() {
    local program_name
    program_name=${0##*/}
    cat <<EOF
Usage: $program_name [-option]

Options:
    --help    Print this message
    --dry-run Print commands without running them
    -y, --yes Skip confirmation prompts
    -s        Clean user caches and junk files
    -a        Clean user caches, junk files, and thumbnails
    --packages
              Clean apt package caches
    --composer
              Clean Composer installer files
    --gems    Run gem cleanup
    --history Clean shell history and z data
    --cache   Clean selected user caches
    --junk    Clean trash, recent files, hsts, and session junk
    --editor-state
              Clean editor backup, swap, shada, undo, and session state
    --thumbnails
              Clean thumbnail caches
    -L        Clean selected system logs
    --system-logs
              Clean selected system logs
EOF
}

run() {
    if "$dry_run"; then
        printf '+'
        printf ' %q' "$@"
        printf '\n'
    else
        "$@"
    fi
}

truncate_file() {
    local file="$1"

    if "$dry_run"; then
        printf '+ : > %q\n' "$file"
    else
        : > "$file"
    fi
}

truncate_system_file() {
    local file="$1"

    if "$dry_run"; then
        printf '+ sudo sh -c %q\n' ": > $file"
    else
        sudo sh -c ": > '$file'"
    fi
}

confirm() {
    local message="$1"
    local response

    read -r -p "$message [y/N] " response
    case "$response" in
        [yY]|[yY][eE][sS])
            return 0
            ;;
        *)
            echo "Cancelled."
            return 1
            ;;
    esac
}

confirm_destructive_clean() {
    local label="$1"

    if "$dry_run" || "$assume_yes"; then
        return 0
    fi

    confirm "This will remove $label. Continue?"
}

clean_packages() {
    echo -e "$magenta\n Cleaning Debian Packages... \n$white"
    run sudo apt clean

    echo -e "$magenta\n Autocleaning Debian Packages... \n$white"
    run sudo apt autoclean

    echo -e "$magenta\n Autoremoving Debian Packages... \n$white"
    run sudo apt autoremove
}

clean_composer() {
    echo -e "$magenta\n Cleaning Composer Installer... \n$white"
    run rm -fv ~/.local/share/composer/20*.phar
}

clean_gems() {
    echo -e "$magenta\n Cleaning Gems... \n$white"
    run gem cleanup
}

clean_history() {
    confirm_destructive_clean "shell history and z data" || return 0
    echo -e "$magenta\n Cleaning Shell History... \n$white"
    truncate_file "$HOME/.bash_history"
    truncate_file "$HOME/.zsh_history"
    truncate_file "$HOME/.z"
    run rm -fv ~/.z.*
}

clean_cache() {
    echo -e "$magenta\n Cleaning Cache... \n$white"
    run rm -rfv ~/.cache/!(chromium|composer|fontconfig|mozilla|pnpm|thumbnails|thunderbird)
}

clean_junk() {
    confirm_destructive_clean "trash, recent files, hsts, and session junk" || return 0
    echo -e "$magenta\n Cleaning Junk Files... \n$white"
    run rm -rfv ~/.local/share/Trash/*
    run rm -fv ~/.local/share/recently-used.xbel
    run rm -fv ~/.lesshst
    run rm -fv ~/.{node_repl,php,python,units}_history
    run rm -fv ~/.wget-hsts
    run rm -fv ~/.xsession-errors*
}

clean_editor_state() {
    confirm_destructive_clean "editor state, backups, swap files, shada, and undo files" || return 0
    echo -e "$magenta\n Cleaning Editor... \n$white"
    run rm -rfv ~/.local/share/nano/search_history
    run rm -rfv ~/.local/share/nvim/backup/*
    run rm -rfv ~/.local/share/nvim/shada/*
    run rm -rfv ~/.local/share/nvim/swap/*
    run rm -rfv ~/.local/share/nvim/undo/*
    run rm -rfv ~/.config/sublime-text-3/Cache/*
    run rm -rfv ~/.config/sublime-text-3/Index/*
    run rm -rfv ~/.config/sublime-text-3/Local/*.sublime_session
    run rm -fv ~/.viminfo
}

clean_thumbnails() {
    echo -e "$magenta\n Cleaning Thumbnails... \n$white"
    run rm -rfv ~/.cache/thumbnails/*
    run rm -rfv ~/.thumbnails/*
}

clean_system_logs() {
    if ! "$dry_run"; then
        confirm "This will truncate selected system logs. Continue?" || return 0
    fi

    echo -e "$magenta\n Cleaning Log System... \n$white"

    run sudo journalctl --vacuum-time=7d
    truncate_system_file /var/log/alternatives.log
    truncate_system_file /var/log/dpkg.log
    truncate_system_file /var/log/lastlog
    truncate_system_file /var/log/wtmp
}

main() {
    local clean_packages_selected=false
    local clean_composer_selected=false
    local clean_gems_selected=false
    local clean_history_selected=false
    local clean_cache_selected=false
    local clean_junk_selected=false
    local clean_editor_selected=false
    local clean_thumb=false
    local clean_logs=false

    if [ "$#" -eq 0 ]; then
        usage
        exit 0
    fi

    while [ "$#" -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            --dry-run)
                dry_run=true
                ;;
            -y|--yes)
                assume_yes=true
                ;;
            -s)
                clean_packages_selected=true
                clean_composer_selected=true
                clean_gems_selected=true
                clean_history_selected=true
                clean_cache_selected=true
                clean_junk_selected=true
                clean_editor_selected=true
                ;;
            -a)
                clean_packages_selected=true
                clean_composer_selected=true
                clean_gems_selected=true
                clean_history_selected=true
                clean_cache_selected=true
                clean_junk_selected=true
                clean_editor_selected=true
                clean_thumb=true
                ;;
            --packages)
                clean_packages_selected=true
                ;;
            --composer)
                clean_composer_selected=true
                ;;
            --gems)
                clean_gems_selected=true
                ;;
            --history)
                clean_history_selected=true
                ;;
            --cache)
                clean_cache_selected=true
                ;;
            --junk)
                clean_junk_selected=true
                ;;
            --editor-state)
                clean_editor_selected=true
                ;;
            --thumbnails)
                clean_thumb=true
                ;;
            -L|--system-logs)
                clean_logs=true
                ;;
            *)
                echo "Command not found: $1"
                exit 1
                ;;
        esac
        shift
    done

    if "$dry_run"; then
        echo -e "$red\n Executing in dry-run mode. \n$white"
    fi

    "$clean_packages_selected" && clean_packages
    "$clean_composer_selected" && clean_composer
    "$clean_gems_selected" && clean_gems
    "$clean_history_selected" && clean_history
    "$clean_cache_selected" && clean_cache
    "$clean_junk_selected" && clean_junk
    "$clean_editor_selected" && clean_editor_state
    "$clean_thumb" && clean_thumbnails
    "$clean_logs" && clean_system_logs
    return 0
}

main "$@"
